  "item": [
    {
      "name": "Is Valid ISBN13 Number",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response time < 3000 ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(3000);\r",
              "});\r",
              "\r",
              "pm.test(\"Content-Type exists\", function () {\r",
              "    pm.expect(pm.response.headers.has(\"Content-Type\")).to.eql(true);\r",
              "});\r",
              "\r",
              "pm.test(\"Content-Type is XML\", function () {\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"xml\");\r",
              "});\r",
              "\r",
              "pm.test(\"Body not empty\", function () {\r",
              "    pm.expect(pm.response.text()).to.not.be.empty;\r",
              "});\r",
              "\r",
              "pm.test(\"SOAP Envelope exists\", function () {\r",
              "    pm.expect(pm.response.text()).to.include(\"Envelope\");\r",
              "});\r",
              "\r",
              "pm.test(\"SOAP Body exists\", function () {\r",
              "    pm.expect(pm.response.text()).to.include(\"Body\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response tag exists\", function () {\r",
              "    pm.expect(pm.response.text()).to.include(\"IsValidISBN13Response\");\r",
              "});\r",
              "\r",
              "pm.test(\"Result tag exists\", function () {\r",
              "    pm.expect(pm.response.text()).to.include(\"IsValidISBN13Result\");\r",
              "});\r",
              "\r",
              "pm.test(\"Result is true or false\", function () {\r",
              "    const body = pm.response.text();\r",
              "    pm.expect(body.includes(\">true<\") || body.includes(\">false<\")).to.eql(true);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [],
            "type": "text/javascript"
          }
        }
